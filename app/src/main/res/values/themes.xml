<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SmartEventManager" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/uvento_yellow</item>
        <item name="colorSecondary">@color/uvento_yellow</item>
        <item name="android:windowBackground">@color/uvento_navy</item>
        <item name="colorSurface">@color/uvento_card</item>
        <item name="colorOnPrimary">@color/uvento_navy</item>
        <item name="colorOnSecondary">@color/uvento_navy</item>
        <item name="android:statusBarColor">@color/uvento_navy</item>
        <item name="android:navigationBarColor">@color/uvento_navy</item>
        <item name="android:colorControlActivated">@color/uvento_yellow</item>
        <item name="android:textCursorDrawable">@null</item>
    </style>

    <style name="Theme.SmartEventManager" parent="Base.Theme.SmartEventManager" />

    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/uvento_card</item>
    </style>

    <style name="UventoInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
        <item name="boxStrokeColor">@color/uvento_input_stroke</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxBackgroundColor">@color/uvento_navy</item>
        <item name="hintTextColor">@color/uvento_yellow</item>
        <item name="android:textColorHint">@color/uvento_text_slate</item>
        <item name="startIconTint">@color/uvento_text_slate</item>
        <item name="errorIconTint">@color/uvento_yellow</item>
        <item name="errorTextColor">@color/uvento_yellow</item>
    </style>

    <style name="RoundedCornersImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PassCardShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">40dp</item>
        <item name="cornerSizeTopRight">40dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>

    <style name="Theme.SmartEventManager.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="colorSurface">@color/uvento_card</item>
        <item name="colorPrimary">@color/uvento_yellow</item>
        <item name="android:textColorPrimary">@color/uvento_text_white</item>
        <item name="android:textColorSecondary">@color/uvento_text_slate</item>
    </style>
</resources>